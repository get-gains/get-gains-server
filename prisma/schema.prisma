// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Sex {
  MALE
  FEMALE
}

enum ExperienceLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum MuscleGroup {
  TRAPS
  SHOULDERS
  CHEST
  ABS
  OBLIQUES
  UPPER_BACK
  LATS
  LOWER_BACK
  BICEPS
  TRICEPS
  FOREARMS
  GLUTES
  QUADS
  HAMSTRINGS
  CALVES
}

enum TargetMuscle {
  // --- TRAPS ---
  UPPER_TRAPS // Shrugs
  MIDDLE_TRAPS // Kelso Shrugs Rows
  LOWER_TRAPS // Y-Raises

  // --- SHOULDERS ---
  FRONT_DELTS // Overhead Press
  SIDE_DELTS // Lateral Raises
  REAR_DELTS // Face Pulls (often overlaps with Upper Back)
  ROTATOR_CUFF // External/Internal rotations (Prehab)

  // --- CHEST ---
  UPPER_PEC // Incline movements (Clavicular head)
  MIDDLE_PEC // Flat movements (Sternal head)
  LOWER_PEC // Decline/Dips (Costal head)
  OUTER_PEC // Flys (Functional focus)

  // --- ABS ---
  UPPER_ABS // Crunches
  LOWER_ABS // Leg Raises

  // --- OBLIQUES ---
  OBLIQUES // Twists/Side Bends
  SERRATUS // Push up plus / Pullovers (The "gill" muscles)

  // --- UPPER_BACK ---
  RHOMBOIDS // Scapular retraction
  TERES_MAJOR // The "mini lat" - width
  TERES_MINOR // Part of rotator cuff but contributes to back look

  // --- LATS ---
  LATS // Vertical pulling / Rows (General)
  // Note: Lats are anatomically one muscle but bodybuilders often split by:
  // UPPER_LATS (Thoracic) vs LOWER_LATS (Iliac/Lumbar)

  // --- LOWER_BACK ---
  ERECTOR_SPINAE // Deadlifts / Extensions

  // --- BICEPS ---
  BICEP_LONG_HEAD // Outer bicep (peak)
  BICEP_SHORT_HEAD // Inner bicep (thickness)
  BRACHIALIS // Muscle under bicep (hammer curls)

  // --- TRICEPS ---
  TRICEP_LONG_HEAD // Overhead work (biggest head)
  TRICEP_LATERAL_HEAD // Pushdowns (horseshoe look)
  TRICEP_MEDIAL_HEAD // Stability / Lockout

  // --- FOREARMS ---
  BRACHIORADIALIS // Top of forearm (Hammer curls/Reverse curls)
  WRIST_FLEXORS // Under forearm
  WRIST_EXTENSORS // Top forearm

  // --- GLUTES ---
  GLUTE_MAX // Main butt muscle (Thrusts/Squats)
  GLUTE_MED_MIN // Upper/Side glute (Abductions)

  // --- QUADS ---
  RECTUS_FEMORIS // Middle thigh / Hip Flexion
  VASTUS_LATERALIS // Outer sweep
  VASTUS_MEDIALIS // Inner teardrop
  VASTUS_INTERMEDIUS // Deep middle

  // --- HAMSTRINGS ---
  BICEPS_FEMORIS // Outer hamstring
  SEMITENDINOSUS // Inner hamstring
  SEMIMEMBRANOSUS // Inner hamstring

  // --- CALVES ---
  GASTROCNEMIUS // Upper calf (diamond shape) - Straight leg
  SOLEUS // Lower calf (width) - Bent knee
  TIBIALIS // Front of shin (often neglected)
}

enum PaymentProvider {
  // Add as we go
  GOOGLE_PAY
}

enum BillingCycle {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  SEMIANNUALLY
  YEARLY
}

// Will have an internal status mapping from different providers to database values
enum SubscriptionStatus {
  PENDING
  ACTIVE
  PAST_DUE
  CANCELED
  EXPIRED
  // Could be refunded or chargeback
  REVOKED
}

enum PaymentStatus {
  COMPLETED
  FAILED
  PENDING
}

enum WebhookStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum SubscriptionEventType {
  CREATED
  RENEWED
  CANCELED
  EXPIRED
  PAUSED
  RESUMED
  UPGRADED
  DOWNGRADED
  REFUNDED
  PAYMENT_FAILED
  PAYMENT_RECOVERED
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
}

model User {
  id                String            @id @default(cuid())
  supabaseId        String            @unique
  email             String            @unique
  name              String
  nickname          String
  createdAt         DateTime          @default(now()) @db.Timestamptz
  updatedAt         DateTime          @updatedAt @db.Timestamptz
  profile           UserProfile?
  coach             Coach?
  subscribedCoaches SubscribedCoach[]
  workoutSessions   WorkoutSession[]
  assignedPrograms  AssignedProgram[]
  subscriptions     Subscription[]
  paymentHistories  PaymentHistory[]
  promoRedemptions  PromoRedemption[]
}

model UserProfile {
  id        String  @id @default(cuid())
  userId    String  @unique
  bio       String?
  avatarUrl String?

  // Personal Data
  heightCm        Float?
  weightKg        Float?
  unitPreference  String?
  sex             Sex?
  dateOfBirth     DateTime?        @db.Timestamptz
  equipment       String[]
  injuryHistory   String?          @db.Text
  experienceLevel ExperienceLevel?

  // Availability
  daysAvailable          Int
  sessionDurationMinutes Int

  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Coach {
  id String @id @default(cuid())

  // Identity
  name      String
  email     String
  avatarUrl String?
  bio       String? @db.Text

  // Credibility Fields
  yearsExperience        Int      @default(0)
  certifications         String[]
  certificationImageUrls String[]
  awards                 String[]
  specialties            String[]
  isVerified             Boolean  @default(false)
  socialLinks            String[]

  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId          String            @unique
  clientRelations SubscribedCoach[]
  programs        Program[]
}

model SubscribedCoach {
  id        String    @id @default(cuid())
  userId    String
  coachId   String
  startedAt DateTime  @default(now()) @db.Timestamptz
  endedAt   DateTime? @db.Timestamptz
  createdAt DateTime  @default(now()) @db.Timestamptz

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  coach Coach @relation(fields: [coachId], references: [id], onDelete: Cascade)

  @@unique([userId, coachId])
}

model Program {
  id          String @id @default(cuid())
  name        String
  description String @db.Text

  coachId String
  coach   Coach  @relation(fields: [coachId], references: [id], onDelete: Cascade)

  createdAt        DateTime          @default(now()) @db.Timestamptz
  updatedAt        DateTime          @updatedAt @db.Timestamptz
  programRoutines  ProgramRoutine[]
  assignedPrograms AssignedProgram[]
}

// Junction: Which routines belong to which program and on what day/order
model ProgramRoutine {
  id String @id @default(cuid())

  programId String
  routineId String
  dayNumber Int // Day 1, Day 2, etc. in the program cycle

  program Program @relation(fields: [programId], references: [id], onDelete: Cascade)
  routine Routine @relation(fields: [routineId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  @@unique([programId, routineId])
}

model Routine {
  id String @id @default(cuid())

  name                     String
  description              String        @db.Text
  estimatedDurationMinutes Int
  muscleGroupsTargeted     MuscleGroup[]

  createdAt        DateTime          @default(now()) @db.Timestamptz
  updatedAt        DateTime          @updatedAt @db.Timestamptz
  routineExercises RoutineExercise[]
  programRoutines  ProgramRoutine[]
}

// Junction: Exercises in a routine with coach-prescribed sets/reps (the template)
model RoutineExercise {
  id String @id @default(cuid())

  routineId  String
  exerciseId String

  sets           Int
  repsMin        Int // Minimum reps (e.g., 8 in "8-12 reps")
  repsMax        Int // Maximum reps (e.g., 12 in "8-12 reps")
  restSeconds    Int
  orderInRoutine Int
  notes          String? @db.Text // Coach notes like "slow eccentric"

  routine  Routine  @relation(fields: [routineId], references: [id], onDelete: Cascade)
  exercise Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  createdAt     DateTime       @default(now()) @db.Timestamptz
  updatedAt     DateTime       @updatedAt @db.Timestamptz
  performedSets PerformedSet[]

  @@unique([routineId, exerciseId])
}

model Exercise {
  id String @id @default(cuid())

  name               String
  description        String         @db.Text
  targetMuscles      TargetMuscle[]
  equipmentNeeded    String[]
  primaryMuscleGroup MuscleGroup

  createdAt        DateTime          @default(now()) @db.Timestamptz
  updatedAt        DateTime          @updatedAt @db.Timestamptz
  routineExercises RoutineExercise[]
}

// A single workout session the user performed
model WorkoutSession {
  id String @id @default(cuid())

  userId            String
  assignedProgramId String?
  startedAt         DateTime  @db.Timestamptz
  completedAt       DateTime? @db.Timestamptz
  notes             String?   @db.Text

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedProgram AssignedProgram? @relation(fields: [assignedProgramId], references: [id], onDelete: SetNull)

  createdAt     DateTime       @default(now()) @db.Timestamptz
  updatedAt     DateTime       @updatedAt @db.Timestamptz
  performedSets PerformedSet[]
}

// Individual set performed by user (the actual work done)
model PerformedSet {
  id String @id @default(cuid())

  workoutSessionId  String
  routineExerciseId String
  setNumber         Int // Which set (1, 2, 3...)

  repsCompleted Int
  weightKg      Float?
  rpe           Int? // Rate of Perceived Exertion (1-10)
  notes         String? @db.Text

  workoutSession  WorkoutSession  @relation(fields: [workoutSessionId], references: [id], onDelete: Cascade)
  routineExercise RoutineExercise @relation(fields: [routineExerciseId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz
}

model AssignedProgram {
  id String @id @default(cuid())

  userId    String
  programId String
  startDate DateTime  @db.Timestamptz
  endDate   DateTime? @db.Timestamptz
  isActive  Boolean   @default(true)

  notes String? @db.Text

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  program Program @relation(fields: [programId], references: [id], onDelete: Cascade)

  createdAt       DateTime         @default(now()) @db.Timestamptz
  updatedAt       DateTime         @updatedAt @db.Timestamptz
  workoutSessions WorkoutSession[]

  @@unique([userId, programId])
}

model Plan {
  id           String       @id @default(cuid())
  name         String       @unique
  description  String       @db.Text
  priceCents   Int
  currency     String       @default("PHP") // ISO 4217 currency code
  billingCycle BillingCycle
  features     String[]

  // Tier level for access control (higher = more access)
  // 0 = Free, 1 = Basic, 2 = Premium, 3 = Pro, etc.
  tierLevel Int @default(0)

  // Provider details
  provider  PaymentProvider
  productId String          @unique // Full composite: "subscriptionId:basePlanId"

  // Separated IDs for reliable matching (client sends only subscriptionId)
  // e.g., productId = "get_gains.premium:premium-subscription"
  //       subscriptionId = "get_gains.premium"
  //       basePlanId = "premium-subscription"
  googleSubscriptionId String? // Just the subscription ID for matching
  googleBasePlanId     String? // Just the base plan ID

  // Trial
  trialPeriodDays Int?
  isActive        Boolean @default(true)
  sortOrder       Int     @default(0)

  createdAt        DateTime         @default(now()) @db.Timestamptz
  updatedAt        DateTime         @updatedAt @db.Timestamptz
  subscriptions    Subscription[]
  paymentHistories PaymentHistory[]

  @@index([googleSubscriptionId])
}

model Subscription {
  id             String             @id @default(cuid())
  userId         String
  planId         String
  subscriptionId String             @unique // External ID
  status         SubscriptionStatus

  // Billing Cycle Tracking
  startDate          DateTime @db.Timestamptz
  currentPeriodStart DateTime @db.Timestamptz
  currentPeriodEnd   DateTime @db.Timestamptz
  nextBillingDate    DateTime @db.Timestamptz

  // Cancellation
  cancelAtPeriodEnd Boolean   @default(false)
  canceledAt        DateTime? @db.Timestamptz
  endedAt           DateTime? @db.Timestamptz

  // Trial tracking
  trialStartDate DateTime? @db.Timestamptz
  orderId        String?   @unique // Latest order ID associated with subscription
  trialEndDate   DateTime? @db.Timestamptz

  // Provider-specific data
  purchaseToken String? // For Google Play subscriptions
  autoRenew     Boolean @default(true)

  metadata Json?

  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan               Plan                @relation(fields: [planId], references: [id], onDelete: Cascade)
  paymentHistories   PaymentHistory[]
  subscriptionEvents SubscriptionEvent[]
  promoRedemptions   PromoRedemption[]
}

model PaymentHistory {
  id             String @id @default(cuid())
  userId         String
  planId         String
  subscriptionId String

  amountCents   Int
  currency      String
  paymentDate   DateTime      @db.Timestamptz
  orderId       String        @unique
  status        PaymentStatus @default(COMPLETED)
  paymentMethod String?
  receiptData   String?       @db.Text

  // Refund tracking
  refundedAt   DateTime? @db.Timestamptz
  refundAmount Int?
  refundReason String?

  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan         Plan         @relation(fields: [planId], references: [id], onDelete: Cascade)
}

// Track all webhook events for debugging and compliance
model WebhookEvent {
  id             String          @id @default(cuid())
  provider       PaymentProvider
  eventType      String // "SUBSCRIPTION_RENEWED", "SUBSCRIPTION_CANCELED", etc.
  subscriptionId String? // Link to subscription if applicable

  // Raw payload data
  rawPayload  Json
  processedAt DateTime @default(now()) @db.Timestamptz

  // Processing status
  status       WebhookStatus @default(PENDING)
  errorMessage String?       @db.Text
  retryCount   Int           @default(0)

  // Request metadata
  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz
}

// Track all subscription state changes for compliance and debugging
model SubscriptionEvent {
  id             String                @id @default(cuid())
  subscriptionId String
  eventType      SubscriptionEventType
  fromStatus     SubscriptionStatus?
  toStatus       SubscriptionStatus?

  // Context
  triggeredBy String? // "user", "system", "webhook", "admin"
  reason      String? @db.Text
  metadata    Json?

  createdAt DateTime @default(now()) @db.Timestamptz

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
}

// Promo codes / coupons system
model PromoCode {
  id          String  @id @default(cuid())
  code        String  @unique
  description String?

  // Discount details
  discountType  DiscountType
  discountValue Int // Percentage (0-100) or cents amount

  // Validity period
  validFrom  DateTime  @db.Timestamptz
  validUntil DateTime? @db.Timestamptz

  // Usage limits
  maxUses     Int? // Null = unlimited
  currentUses Int  @default(0)

  // Restrictions
  applicablePlans String[] // Plan IDs this applies to (empty = all plans)
  firstTimeOnly   Boolean  @default(false) // Only for users with no previous subscriptions

  isActive Boolean @default(true)

  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  redemptions PromoRedemption[]
}

model PromoRedemption {
  id             String   @id @default(cuid())
  promoCodeId    String
  userId         String
  subscriptionId String?
  redeemedAt     DateTime @default(now()) @db.Timestamptz

  promoCode    PromoCode     @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
}
