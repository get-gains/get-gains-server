// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============== Enums ==============

enum CameraAngle {
  FRONT
  SIDE_LEFT
  SIDE_RIGHT
  REAR
  ANGLE_45_LEFT
  ANGLE_45_RIGHT
}

enum BodySegment {
  HEAD_NECK
  LEFT_ARM
  RIGHT_ARM
  TORSO
  LEFT_LEG
  RIGHT_LEG
  FULL_BODY
}

enum CoinTransactionType {
  SESSION_REWARD
  SHOP_PURCHASE
  MISSION_REWARD
}

// ============== RevenueCat Enums ==============

enum SubscriptionTier {
  FREE
  PREMIUM
}

enum RcSubscriptionStatus {
  ACTIVE
  TRIALING
  GRACE_PERIOD
  PAUSED
  EXPIRED
  CANCELLED
}

enum SubscriptionStore {
  APP_STORE
  PLAY_STORE
  STRIPE
  PROMOTIONAL
}

enum RcEventType {
  INITIAL_PURCHASE
  RENEWAL
  CANCELLATION
  UNCANCELLATION
  NON_RENEWING_PURCHASE
  EXPIRATION
  BILLING_ISSUE
  PRODUCT_CHANGE
  TRANSFER
  SUBSCRIPTION_PAUSED
  SUBSCRIPTION_EXTENDED
  TEMPORARY_ENTITLEMENT_GRANT
  REFUND
  TEST
}

enum RcEventStatus {
  PENDING
  COMPLETED
  FAILED
}

enum RewardType {
  COINS
  RAFFLE
  COUPON
}

enum CosmeticCategory {
  HEADWEAR
  TOP
  BOTTOM
  ACCESSORY
}

enum DayOfWeek {
  SUNDAY
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
}

enum NotificationType {
  program_assigned
  coach_subscribed
  roster_removed
  subscription_expiring
  mission_raffle_won
  mission_coupon_earned
}

enum CoachInviteStatus {
  PENDING
  REDEEMED
  REVOKED
}

// ============== Auth / OTP ==============

model password_reset_otp {
  id             String     @id @default(cuid())
  email          String
  code           String
  attempts       Int        @default(0)
  max_attempts   Int        @default(3)
  verified       Boolean    @default(false)
  reset_token    String?    @unique
  expires_at     DateTime   @db.Timestamptz
  cooldown_until DateTime?  @db.Timestamptz
  created_at     DateTime   @default(now()) @db.Timestamptz

  @@index([email, verified, expires_at])
  @@index([reset_token])
}

// ============== Identity ==============

model user {
  supabase_auth_id    String      @id
  email               String      @unique
  full_name           String
  nickname            String
  is_coach            Boolean     @default(false)
  is_admin            Boolean     @default(false)
  bio                 String?     @db.Text
  avatar_key          String?
  height_cm           Int?
  weight_kg           Int?
  sex                 String?
  date_of_birth       DateTime?   @db.Timestamptz
  equipment_available String[]
  experience_level    String?
  injury_history      String?     @db.Text
  active_weekdays     DayOfWeek[]
  coin_balance        Int         @default(0)
  deleted_at          DateTime?   @db.Timestamptz
  created_at          DateTime    @default(now()) @db.Timestamptz
  updated_at          DateTime    @updatedAt @db.Timestamptz

  // Denormalized for O(1) tier gate checks. Updated by RC webhook handler.
  active_subscription_tier SubscriptionTier @default(FREE)

  // Standalone (free-tier) workout stats — separate from coach-tier counters.
  standalone_streak_days       Int       @default(0)
  standalone_last_workout_date DateTime? @db.Timestamptz

  coach                  coach?
  subscribed_coaches     subscribed_coach[]
  created_invitations    coach_invitation[]    @relation("AdminCreatedInvitations")
  redeemed_invitations   coach_invitation[]    @relation("CoachRedeemedInvitations")
  revoked_invitations    coach_invitation[]    @relation("AdminRevokedInvitations")
  routines               routine[]
  exercises              exercise[]
  coached_programs       assigned_program[]      @relation("CoachPrograms")
  client_programs        assigned_program[]      @relation("ClientPrograms")
  coin_transactions      coin_transactions[]
  user_cosmetics         user_cosmetic[]
  user_missions          user_mission[]
  user_coupons           user_coupon[]
  raffle_winners         raffle_winner[]
  user_subscription      user_subscription?
  rc_subscription_events rc_subscription_event[]
  exercise_ratings       exercise_rating[]
  notifications          notification[]
  standalone_programs    standalone_program[]
  standalone_sessions    standalone_session[]
}

model coach {
  user_id           String   @id
  certifications    String[]
  specialties       String[]
  social_links      String[]
  max_clients       Int      @default(40)
  accepting_clients Boolean  @default(true)
  is_discoverable   Boolean  @default(true)
  years_experience  Int?
  deactivated_at    DateTime? @db.Timestamptz
  created_at        DateTime @default(now()) @db.Timestamptz
  updated_at        DateTime @updatedAt @db.Timestamptz

  user             user               @relation(fields: [user_id], references: [supabase_auth_id], onDelete: Cascade)
  client_relations subscribed_coach[]
}

model subscribed_coach {
  id         String    @id @default(cuid())
  coach_id   String
  user_id    String
  started_at DateTime  @default(now()) @db.Timestamptz
  ended_at   DateTime? @db.Timestamptz
  created_at DateTime  @default(now()) @db.Timestamptz
  updated_at DateTime  @updatedAt @db.Timestamptz

  coach coach @relation(fields: [coach_id], references: [user_id], onDelete: Cascade)
  user  user  @relation(fields: [user_id], references: [supabase_auth_id], onDelete: Cascade)

  @@index([user_id])
  @@index([coach_id])
}

model coach_invitation {
  id           String            @id @default(cuid())
  email        String
  code         String
  status       CoachInviteStatus @default(PENDING)
  attempts     Int               @default(0)
  max_attempts Int               @default(3)
  expires_at   DateTime          @db.Timestamptz
  created_by   String
  redeemed_by  String?
  redeemed_at  DateTime?         @db.Timestamptz
  revoked_by   String?
  revoked_at   DateTime?         @db.Timestamptz
  created_at   DateTime          @default(now()) @db.Timestamptz
  updated_at   DateTime          @updatedAt @db.Timestamptz

  creator user? @relation("AdminCreatedInvitations", fields: [created_by], references: [supabase_auth_id], onDelete: Cascade)
  redeemer user? @relation("CoachRedeemedInvitations", fields: [redeemed_by], references: [supabase_auth_id], onDelete: SetNull)
  revoker user? @relation("AdminRevokedInvitations", fields: [revoked_by], references: [supabase_auth_id], onDelete: SetNull)

  @@index([email, status, expires_at])
  @@index([code, status])
}

// ============== Notifications ==============

model notification {
  id         String           @id @default(uuid())
  user_id    String
  type       NotificationType
  title      String
  body       String
  data       Json?
  is_read    Boolean          @default(false)
  created_at DateTime         @default(now()) @db.Timestamptz
  read_at    DateTime?        @db.Timestamptz

  user user @relation(fields: [user_id], references: [supabase_auth_id], onDelete: Cascade)

  @@index([user_id, is_read, created_at(sort: Desc)])
  @@index([user_id, created_at(sort: Desc)])
  @@map("notifications")
}

// ============== Training Library (Coach Templates) ==============

model routine {
  id                         String    @id @default(cuid())
  user_id                    String
  name                       String
  description                String    @db.Text
  estimated_duration_minutes Int
  deleted_at                 DateTime? @db.Timestamptz
  created_at                 DateTime  @default(now()) @db.Timestamptz
  updated_at                 DateTime  @updatedAt @db.Timestamptz

  user                      user                       @relation(fields: [user_id], references: [supabase_auth_id], onDelete: Cascade)
  assigned_program_routines assigned_program_routine[]
  standalone_routines       standalone_program_routine[]

  @@index([user_id])
}

model exercise {
  id              String    @id @default(cuid())
  user_id         String
  name            String
  description     String    @db.Text
  target_muscles  String[]
  active_segments String[]
  is_public       Boolean   @default(false)
  thumbs_up_count Int       @default(0)
  deleted_at      DateTime? @db.Timestamptz
  created_at      DateTime  @default(now()) @db.Timestamptz
  updated_at      DateTime  @updatedAt @db.Timestamptz

  user                               user                                @relation(fields: [user_id], references: [supabase_auth_id], onDelete: Cascade)
  exercise_forms                     exercise_form[]
  assigned_program_routine_exercises assigned_program_routine_exercise[]
  standalone_exercises               standalone_program_routine_exercise[]
  exercise_ratings                   exercise_rating[]

  @@index([user_id])
  @@index([is_public])
}

model exercise_rating {
  id          String   @id @default(cuid())
  exercise_id String
  user_id     String
  created_at  DateTime @default(now()) @db.Timestamptz

  exercise exercise @relation(fields: [exercise_id], references: [id], onDelete: Cascade)
  user     user     @relation(fields: [user_id], references: [supabase_auth_id], onDelete: Cascade)

  @@unique([exercise_id, user_id])
  @@index([exercise_id])
}

model exercise_form {
  id                  String      @id @default(cuid())
  exercise_id         String
  camera_angle        CameraAngle
  recorded_frames_key String
  created_at          DateTime    @default(now()) @db.Timestamptz
  updated_at          DateTime    @updatedAt @db.Timestamptz

  exercise exercise @relation(fields: [exercise_id], references: [id], onDelete: Cascade)

  @@index([exercise_id, camera_angle])
}

// ============== Assignment & Execution (Snapshot Pattern) ==============

model assigned_program {
  id          String    @id @default(cuid())
  user_id     String
  coach_id    String
  name        String
  description String    @db.Text
  notes       String?   @db.Text
  is_active   Boolean   @default(true)
  start_date  DateTime? @db.Timestamptz
  end_date    DateTime? @db.Timestamptz
  deleted_at  DateTime? @db.Timestamptz
  created_at  DateTime  @default(now()) @db.Timestamptz
  updated_at  DateTime  @updatedAt @db.Timestamptz

  user                      user                       @relation("ClientPrograms", fields: [user_id], references: [supabase_auth_id], onDelete: Cascade)
  coach                     user                       @relation("CoachPrograms", fields: [coach_id], references: [supabase_auth_id], onDelete: Cascade)
  assigned_program_routines assigned_program_routine[]

  @@index([user_id])
  @@index([coach_id])
}

model assigned_program_routine {
  id                         String    @id @default(cuid())
  assigned_program_id        String
  source_routine_id          String?
  name                       String
  description                String    @db.Text
  estimated_duration_minutes Int
  order_in_program           Int
  days_of_week               String[]
  deleted_at                 DateTime? @db.Timestamptz
  created_at                 DateTime  @default(now()) @db.Timestamptz
  updated_at                 DateTime  @updatedAt @db.Timestamptz

  source_routine                     routine?                            @relation(fields: [source_routine_id], references: [id], onDelete: SetNull)
  assigned_program                   assigned_program                    @relation(fields: [assigned_program_id], references: [id], onDelete: Cascade)
  assigned_program_routine_exercises assigned_program_routine_exercise[]
  workout_sessions                   workout_session[]

  @@index([assigned_program_id])
  @@index([source_routine_id])
}

model assigned_program_routine_exercise {
  id                          String    @id @default(cuid())
  assigned_program_routine_id String
  exercise_id                 String
  sets                        Int
  reps_min                    Int
  reps_max                    Int
  rest_seconds                Int
  order_in_routine            Int
  deleted_at                  DateTime? @db.Timestamptz
  created_at                  DateTime  @default(now()) @db.Timestamptz
  updated_at                  DateTime  @updatedAt @db.Timestamptz

  assigned_program_routine assigned_program_routine @relation(fields: [assigned_program_routine_id], references: [id], onDelete: Cascade)
  exercise                 exercise                 @relation(fields: [exercise_id], references: [id], onDelete: Restrict)
  performed_sets           performed_set[]

  @@index([assigned_program_routine_id])
  @@index([exercise_id])
}

model workout_session {
  id                          String    @id @default(cuid())
  assigned_program_routine_id String
  started_at                  DateTime? @db.Timestamptz
  completed_at                DateTime? @db.Timestamptz
  feedback                    String?   @db.Text
  deleted_at                  DateTime? @db.Timestamptz
  created_at                  DateTime  @default(now()) @db.Timestamptz
  updated_at                  DateTime  @updatedAt @db.Timestamptz

  assigned_program_routine assigned_program_routine @relation(fields: [assigned_program_routine_id], references: [id], onDelete: Cascade)
  performed_sets           performed_set[]
  coin_transactions        coin_transactions[]

  @@index([assigned_program_routine_id])
  @@index([completed_at])
}

model performed_set {
  id                                   String    @id @default(cuid())
  workout_session_id                   String
  assigned_program_routine_exercise_id String
  set_number                           Int
  reps                                 Int
  weight                               Float
  overall_score                        Int
  recorded_frames_key                  String?
  completed_at                         DateTime  @db.Timestamptz
  deleted_at                           DateTime? @db.Timestamptz
  created_at                           DateTime  @default(now()) @db.Timestamptz
  updated_at                           DateTime  @updatedAt @db.Timestamptz
  // Snapshot columns — populated at set-creation time, never updated from upstream
  exercise_name_snapshot               String?
  target_reps_min                      Int?
  target_reps_max                      Int?
  target_rest_seconds                  Int?
  target_weight_kg                     Float?

  workout_session                   workout_session                   @relation(fields: [workout_session_id], references: [id], onDelete: Cascade)
  assigned_program_routine_exercise assigned_program_routine_exercise @relation(fields: [assigned_program_routine_exercise_id], references: [id], onDelete: Cascade)

  @@index([workout_session_id])
  @@index([assigned_program_routine_exercise_id])
  @@index([completed_at])
}

// ============== Standalone Workout (Free Tier) ==============

model standalone_program {
  id          String    @id @default(cuid())
  user_id     String
  name        String
  description String    @default("") @db.Text
  is_active   Boolean   @default(false)
  deleted_at  DateTime? @db.Timestamptz
  created_at  DateTime  @default(now()) @db.Timestamptz
  updated_at  DateTime  @updatedAt @db.Timestamptz

  user     user                          @relation(fields: [user_id], references: [supabase_auth_id], onDelete: Cascade)
  routines standalone_program_routine[]

  @@index([user_id, deleted_at])
}

model standalone_program_routine {
  id               String    @id @default(cuid())
  program_id       String
  routine_id       String
  order_in_program Int       @default(1)
  deleted_at       DateTime? @db.Timestamptz
  created_at       DateTime  @default(now()) @db.Timestamptz

  program   standalone_program                 @relation(fields: [program_id], references: [id], onDelete: Cascade)
  routine   routine                            @relation(fields: [routine_id], references: [id], onDelete: Restrict)
  exercises standalone_program_routine_exercise[]
  sessions  standalone_session[]

  @@index([program_id])
  @@index([routine_id])
}

model standalone_program_routine_exercise {
  id                String    @id @default(cuid())
  program_routine_id String
  exercise_id       String
  sets              Int       @default(3)
  reps_min          Int       @default(8)
  reps_max          Int       @default(12)
  rest_seconds      Int       @default(60)
  order_in_routine  Int       @default(1)
  deleted_at        DateTime? @db.Timestamptz
  created_at        DateTime  @default(now()) @db.Timestamptz

  program_routine standalone_program_routine @relation(fields: [program_routine_id], references: [id], onDelete: Cascade)
  exercise        exercise                   @relation(fields: [exercise_id], references: [id], onDelete: Restrict)
  performed_sets  standalone_performed_set[]

  @@index([program_routine_id])
  @@index([exercise_id])
}

model standalone_session {
  id                String    @id @default(cuid())
  user_id           String
  program_routine_id String
  started_at        DateTime  @default(now()) @db.Timestamptz
  completed_at      DateTime? @db.Timestamptz
  feedback          String?   @db.Text
  deleted_at        DateTime? @db.Timestamptz
  created_at        DateTime  @default(now()) @db.Timestamptz

  user            user                        @relation(fields: [user_id], references: [supabase_auth_id], onDelete: Cascade)
  program_routine standalone_program_routine  @relation(fields: [program_routine_id], references: [id], onDelete: Cascade)
  performed_sets  standalone_performed_set[]

  @@index([user_id, completed_at])
  @@index([program_routine_id])
}

model standalone_performed_set {
  id                 String   @id @default(cuid())
  session_id         String
  routine_exercise_id String
  set_number         Int
  reps               Int
  weight             Float    @default(0)
  created_at         DateTime @default(now()) @db.Timestamptz

  session  standalone_session                @relation(fields: [session_id], references: [id], onDelete: Cascade)
  exercise standalone_program_routine_exercise @relation(fields: [routine_exercise_id], references: [id], onDelete: Cascade)

  @@unique([session_id, routine_exercise_id, set_number])
  @@index([session_id])
  @@index([routine_exercise_id])
}

// ============== Gamification ==============

model cosmetics {
  id                String           @id @default(cuid())
  name              String
  description       String           @db.Text
  tier              Int
  price             Int
  preview_image_key String
  unity_asset_ref   String           @unique @default("")
  category          CosmeticCategory @default(HEADWEAR)
  status            String           @default("ACTIVE")
  sort_order        Int              @default(0)
  deleted_at        DateTime?        @db.Timestamptz
  created_at        DateTime         @default(now()) @db.Timestamptz
  updated_at        DateTime         @updatedAt @db.Timestamptz

  user_cosmetics user_cosmetic[]
}

model user_cosmetic {
  user_id     String
  cosmetic_id String
  equipped_at DateTime? @db.Timestamptz
  created_at  DateTime  @default(now()) @db.Timestamptz
  updated_at  DateTime  @updatedAt @db.Timestamptz

  user              user                @relation(fields: [user_id], references: [supabase_auth_id], onDelete: Cascade)
  cosmetic          cosmetics           @relation(fields: [cosmetic_id], references: [id], onDelete: Restrict)
  coin_transactions coin_transactions[]

  @@id([user_id, cosmetic_id])
  @@index([user_id])
}

model coin_transactions {
  id                        String              @id @default(cuid())
  user_id                   String
  transaction_type          CoinTransactionType
  value                     Int
  balance_after             Int
  // Earning breakdown (null for spending transactions)
  set_coins                 Int?
  accuracy_multiplier       Float?
  completion_bonus          Int?
  duration_bonus            Int?
  streak_bonus              Int?
  streak_value              Int?
  sets_completed            Int?
  avg_accuracy              Float?
  session_duration_min      Int?
  // References
  workout_session_id        String?
  user_cosmetic_user_id     String?
  user_cosmetic_cosmetic_id String?
  user_mission_id           String?
  created_at                DateTime            @default(now()) @db.Timestamptz

  user            user             @relation(fields: [user_id], references: [supabase_auth_id], onDelete: Cascade)
  workout_session workout_session? @relation(fields: [workout_session_id], references: [id], onDelete: SetNull)
  user_cosmetic   user_cosmetic?   @relation(fields: [user_cosmetic_user_id, user_cosmetic_cosmetic_id], references: [user_id, cosmetic_id], onDelete: SetNull)
  user_mission    user_mission?    @relation(fields: [user_mission_id], references: [id], onDelete: SetNull)

  @@index([user_id, created_at])
  @@index([workout_session_id])
  @@index([user_mission_id])
}

// ============== Missions & Partners ==============

model partner {
  id           String   @id @default(cuid())
  name         String
  logo_key     String
  bio          String   @db.Text
  social_links String[]
  created_at   DateTime @default(now()) @db.Timestamptz
  updated_at   DateTime @updatedAt @db.Timestamptz

  missions mission[]
}

model mission {
  id                 String     @id @default(cuid())
  partner_id         String?
  title              String
  description        String     @db.Text
  goal_type          String
  goal_to_reach      Int
  reward_type        RewardType @default(COINS)
  reward_coins       Int        @default(0)
  reward_title       String?
  reward_description String?    @db.Text
  reward_image_key   String?
  max_winners        Int?
  is_repeatable      Boolean    @default(false)
  is_closed          Boolean    @default(false)
  starts_at          DateTime?  @db.Timestamptz
  ends_at            DateTime?  @db.Timestamptz
  created_at         DateTime   @default(now()) @db.Timestamptz
  updated_at         DateTime   @updatedAt @db.Timestamptz

  partner       partner?       @relation(fields: [partner_id], references: [id], onDelete: SetNull)
  user_missions user_mission[]
  coupon        coupon?
  raffle_winners raffle_winner[]

  @@index([partner_id])
  @@index([starts_at, ends_at])
}


model user_mission {
  id           String    @id @default(cuid())
  user_id      String
  mission_id   String
  status       String
  progress     Int       @default(0)
  completed_at DateTime? @db.Timestamptz
  created_at   DateTime  @default(now()) @db.Timestamptz
  updated_at   DateTime  @updatedAt @db.Timestamptz

  user               user                @relation(fields: [user_id], references: [supabase_auth_id], onDelete: Cascade)
  mission            mission             @relation(fields: [mission_id], references: [id], onDelete: Cascade)
  raffle_entries     raffle_entry[]
  coin_transactions  coin_transactions[]

  @@unique([user_id, mission_id])
  @@index([user_id])
  @@index([mission_id])
}

model raffle_entry {
  id              String   @id @default(cuid())
  user_mission_id String
  is_winner       Boolean  @default(false)
  created_at      DateTime @default(now()) @db.Timestamptz
  updated_at      DateTime @updatedAt @db.Timestamptz

  user_mission user_mission @relation(fields: [user_mission_id], references: [id], onDelete: Cascade)

  @@index([user_mission_id])
}

model coupon {
  id               String   @id @default(cuid())
  mission_id       String   @unique
  offer_tag        String
  description      String?  @db.Text
  discount_percent Int      @default(20)
  created_at       DateTime @default(now()) @db.Timestamptz
  updated_at       DateTime @updatedAt @db.Timestamptz

  mission      mission       @relation(fields: [mission_id], references: [id], onDelete: Cascade)
  user_coupons user_coupon[]
}

model user_coupon {
  id           String    @id @default(cuid())
  user_id      String
  coupon_id    String
  claimed_at   DateTime  @default(now()) @db.Timestamptz
  created_at   DateTime  @default(now()) @db.Timestamptz

  user   user    @relation(fields: [user_id], references: [supabase_auth_id], onDelete: Cascade)
  coupon coupon  @relation(fields: [coupon_id], references: [id], onDelete: Cascade)

  @@unique([user_id, coupon_id])
  @@index([user_id])
  @@index([coupon_id])
}

model raffle_winner {
  id         String   @id @default(cuid())
  mission_id String
  user_id    String
  rank       Int
  created_at DateTime @default(now()) @db.Timestamptz

  mission mission @relation(fields: [mission_id], references: [id], onDelete: Cascade)
  user    user    @relation(fields: [user_id], references: [supabase_auth_id], onDelete: Cascade)

  @@index([mission_id])
  @@index([user_id])
}

// ============== RevenueCat Subscription Domain ==============

model user_subscription {
  user_id String @id
  user    user   @relation(fields: [user_id], references: [supabase_auth_id], onDelete: Cascade)

  tier   SubscriptionTier
  status RcSubscriptionStatus
  store  SubscriptionStore

  entitlement_id    String
  product_id        String
  rc_original_tx_id String? @unique

  current_period_start DateTime  @db.Timestamptz
  current_period_end   DateTime  @db.Timestamptz
  trial_ends_at        DateTime? @db.Timestamptz
  cancel_at_period_end Boolean   @default(false)
  will_renew           Boolean   @default(true)

  created_at DateTime @default(now()) @db.Timestamptz
  updated_at DateTime @updatedAt @db.Timestamptz

  @@index([status, current_period_end])
  @@index([tier, status])
}

model rc_subscription_event {
  id      String @id @default(cuid())
  user_id String
  user    user   @relation(fields: [user_id], references: [supabase_auth_id], onDelete: Cascade)

  event_type RcEventType
  status     RcEventStatus @default(PENDING)

  from_tier   SubscriptionTier?
  to_tier     SubscriptionTier?
  from_status RcSubscriptionStatus?
  to_status   RcSubscriptionStatus?

  store          SubscriptionStore?
  product_id     String?
  entitlement_id String?

  rc_event_id String   @unique
  occurred_at DateTime @db.Timestamptz

  raw_payload   Json
  error_message String?   @db.Text
  retry_count   Int       @default(0)
  processed_at  DateTime? @db.Timestamptz

  created_at DateTime @default(now()) @db.Timestamptz

  @@index([user_id, occurred_at(sort: Desc)])
  @@index([status, created_at])
}
