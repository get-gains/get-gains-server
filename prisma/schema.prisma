// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============== Enums ==============

enum BillingCycle {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  SEMIANNUALLY
  YEARLY
}

enum SubscriptionStatus {
  PENDING
  ACTIVE
  PAST_DUE
  CANCELED
  EXPIRED
  REVOKED
  PAUSED
}

enum PaymentStatus {
  COMPLETED
  FAILED
  PENDING
  REFUNDED
}

enum WebhookStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum CameraAngle {
  FRONT
  SIDE_LEFT
  SIDE_RIGHT
  REAR
  ANGLE_45_LEFT
  ANGLE_45_RIGHT
}

enum BodySegment {
  HEAD_NECK
  LEFT_ARM
  RIGHT_ARM
  TORSO
  LEFT_LEG
  RIGHT_LEG
  FULL_BODY
}

enum CoinTransactionType {
  SESSION_REWARD
  SHOP_PURCHASE
}

enum Provider {
  GOOGLE_PLAY
  APPLE
}

// ============== Identity ==============

model user {
  supabase_auth_id    String    @id
  email               String    @unique
  full_name           String
  nickname            String
  is_coach            Boolean   @default(false)
  bio                 String?   @db.Text
  avatar_key          String?
  height_cm           Int?
  weight_kg           Int?
  sex                 String?
  date_of_birth       DateTime? @db.Timestamptz
  equipment_available String[]
  experience_level    String?
  active_weekdays     String[]
  coin_balance        Int       @default(0)
  deleted_at          DateTime? @db.Timestamptz
  created_at          DateTime  @default(now()) @db.Timestamptz
  updated_at          DateTime  @updatedAt @db.Timestamptz

  coach              coach?
  subscribed_coaches subscribed_coach[]
  programs           program[]
  routines           routine[]
  exercises          exercise[]
  assigned_programs  assigned_program[]
  subscriptions      subscription[]
  payment_histories  payment_history[]
  coin_transactions  coin_transactions[]
  user_cosmetics     user_cosmetic[]
  user_missions      user_mission[]
}

model coach {
  user_id           String   @id
  certifications    String[]
  specialties       String[]
  social_links      String[]
  max_clients       Int      @default(40)
  accepting_clients Boolean  @default(true)
  is_discoverable   Boolean  @default(true)
  created_at        DateTime @default(now()) @db.Timestamptz
  updated_at        DateTime @updatedAt @db.Timestamptz

  user             user               @relation(fields: [user_id], references: [supabase_auth_id], onDelete: Cascade)
  client_relations subscribed_coach[]
}

model subscribed_coach {
  id         String    @id @default(cuid())
  coach_id   String
  user_id    String
  started_at DateTime  @default(now()) @db.Timestamptz
  ended_at   DateTime? @db.Timestamptz
  created_at DateTime  @default(now()) @db.Timestamptz
  updated_at DateTime  @updatedAt @db.Timestamptz

  coach coach @relation(fields: [coach_id], references: [user_id], onDelete: Cascade)
  user  user  @relation(fields: [user_id], references: [supabase_auth_id], onDelete: Cascade)

  @@index([user_id])
  @@index([coach_id])
}

// ============== Training Library ==============

model program {
  id          String    @id @default(cuid())
  user_id     String
  name        String
  description String    @db.Text
  deleted_at  DateTime? @db.Timestamptz
  created_at  DateTime  @default(now()) @db.Timestamptz
  updated_at  DateTime  @updatedAt @db.Timestamptz

  user              user               @relation(fields: [user_id], references: [supabase_auth_id], onDelete: Cascade)
  assigned_programs assigned_program[]

  @@index([user_id])
}

model routine {
  id                         String    @id @default(cuid())
  user_id                    String
  name                       String
  description                String    @db.Text
  estimated_duration_minutes Int
  deleted_at                 DateTime? @db.Timestamptz
  created_at                 DateTime  @default(now()) @db.Timestamptz
  updated_at                 DateTime  @updatedAt @db.Timestamptz

  user                      user                       @relation(fields: [user_id], references: [supabase_auth_id], onDelete: Cascade)
  assigned_program_routines assigned_program_routine[]

  @@index([user_id])
}

model exercise {
  id              String    @id @default(cuid())
  user_id         String
  name            String
  description     String    @db.Text
  target_muscles  String[]
  active_segments String[]
  is_public       Boolean   @default(false)
  deleted_at      DateTime? @db.Timestamptz
  created_at      DateTime  @default(now()) @db.Timestamptz
  updated_at      DateTime  @updatedAt @db.Timestamptz

  user                               user                                @relation(fields: [user_id], references: [supabase_auth_id], onDelete: Cascade)
  exercise_forms                     exercise_form[]
  assigned_program_routine_exercises assigned_program_routine_exercise[]

  @@index([user_id])
  @@index([is_public])
}

model exercise_form {
  id                  String      @id @default(cuid())
  exercise_id         String
  camera_angle        CameraAngle
  recorded_frames_key String
  created_at          DateTime    @default(now()) @db.Timestamptz
  updated_at          DateTime    @updatedAt @db.Timestamptz

  exercise exercise @relation(fields: [exercise_id], references: [id], onDelete: Cascade)

  @@index([exercise_id, camera_angle])
}

// ============== Assignment & Execution (Snapshot Pattern) ==============

model assigned_program {
  id         String    @id @default(cuid())
  user_id    String
  program_id String
  notes      String?   @db.Text
  start_date DateTime? @db.Timestamptz
  end_date   DateTime? @db.Timestamptz
  created_at DateTime  @default(now()) @db.Timestamptz
  updated_at DateTime  @updatedAt @db.Timestamptz

  user                      user                       @relation(fields: [user_id], references: [supabase_auth_id], onDelete: Cascade)
  program                   program                    @relation(fields: [program_id], references: [id], onDelete: Cascade)
  assigned_program_routines assigned_program_routine[]

  @@index([user_id])
  @@index([program_id])
}

model assigned_program_routine {
  id                  String    @id @default(cuid())
  routine_id          String
  assigned_program_id String
  days_of_week        String[]
  deleted_at          DateTime? @db.Timestamptz
  created_at          DateTime  @default(now()) @db.Timestamptz
  updated_at          DateTime  @updatedAt @db.Timestamptz

  routine                            routine                             @relation(fields: [routine_id], references: [id], onDelete: Cascade)
  assigned_program                   assigned_program                    @relation(fields: [assigned_program_id], references: [id], onDelete: Cascade)
  assigned_program_routine_exercises assigned_program_routine_exercise[]
  workout_sessions                   workout_session[]

  @@index([assigned_program_id])
  @@index([routine_id])
}

model assigned_program_routine_exercise {
  id                          String    @id @default(cuid())
  assigned_program_routine_id String
  exercise_id                 String
  sets                        Int
  reps_min                    Int
  reps_max                    Int
  rest_seconds                Int
  order_in_routine            Int
  deleted_at                  DateTime? @db.Timestamptz
  created_at                  DateTime  @default(now()) @db.Timestamptz
  updated_at                  DateTime  @updatedAt @db.Timestamptz

  assigned_program_routine assigned_program_routine @relation(fields: [assigned_program_routine_id], references: [id], onDelete: Cascade)
  exercise                 exercise                 @relation(fields: [exercise_id], references: [id], onDelete: Restrict)
  performed_sets           performed_set[]

  @@index([assigned_program_routine_id])
  @@index([exercise_id])
}

model workout_session {
  id                          String    @id @default(cuid())
  assigned_program_routine_id String
  started_at                  DateTime? @db.Timestamptz
  completed_at                DateTime? @db.Timestamptz
  feedback                    String?   @db.Text
  deleted_at                  DateTime? @db.Timestamptz
  created_at                  DateTime  @default(now()) @db.Timestamptz
  updated_at                  DateTime  @updatedAt @db.Timestamptz

  assigned_program_routine assigned_program_routine @relation(fields: [assigned_program_routine_id], references: [id], onDelete: Cascade)
  performed_sets           performed_set[]
  coin_transactions        coin_transactions[]

  @@index([assigned_program_routine_id])
  @@index([completed_at])
}

model performed_set {
  id                                   String    @id @default(cuid())
  workout_session_id                   String
  assigned_program_routine_exercise_id String
  set_number                           Int
  reps                                 Int
  weight                               Float
  overall_score                        Int
  recorded_frames_key                  String?
  completed_at                         DateTime  @db.Timestamptz
  deleted_at                           DateTime? @db.Timestamptz
  created_at                           DateTime  @default(now()) @db.Timestamptz
  updated_at                           DateTime  @updatedAt @db.Timestamptz

  workout_session                   workout_session                   @relation(fields: [workout_session_id], references: [id], onDelete: Cascade)
  assigned_program_routine_exercise assigned_program_routine_exercise @relation(fields: [assigned_program_routine_exercise_id], references: [id], onDelete: Cascade)

  @@index([workout_session_id])
  @@index([assigned_program_routine_exercise_id])
}

// ============== Gamification ==============

model cosmetics {
  id                String    @id @default(cuid())
  name              String
  description       String    @db.Text
  tier              Int
  price             Int
  category          String
  preview_image_key String
  deleted_at        DateTime? @db.Timestamptz
  created_at        DateTime  @default(now()) @db.Timestamptz
  updated_at        DateTime  @updatedAt @db.Timestamptz

  user_cosmetics user_cosmetic[]

  @@index([category])
}

model user_cosmetic {
  user_id     String
  cosmetic_id String
  equipped_at DateTime? @db.Timestamptz
  created_at  DateTime  @default(now()) @db.Timestamptz
  updated_at  DateTime  @updatedAt @db.Timestamptz

  user              user                @relation(fields: [user_id], references: [supabase_auth_id], onDelete: Cascade)
  cosmetic          cosmetics           @relation(fields: [cosmetic_id], references: [id], onDelete: Restrict)
  coin_transactions coin_transactions[]

  @@id([user_id, cosmetic_id])
  @@index([user_id])
}

model coin_transactions {
  id                        String              @id @default(cuid())
  user_id                   String
  transaction_type          CoinTransactionType
  value                     Int
  balance_after             Int
  // Earning breakdown (null for spending transactions)
  set_coins                 Int?
  accuracy_multiplier       Float?
  completion_bonus          Int?
  duration_bonus            Int?
  streak_bonus              Int?
  streak_value              Int?
  sets_completed            Int?
  avg_accuracy              Float?
  session_duration_min      Int?
  // References
  workout_session_id        String?
  user_cosmetic_user_id     String?
  user_cosmetic_cosmetic_id String?
  created_at                DateTime            @default(now()) @db.Timestamptz

  user            user             @relation(fields: [user_id], references: [supabase_auth_id], onDelete: Cascade)
  workout_session workout_session? @relation(fields: [workout_session_id], references: [id], onDelete: SetNull)
  user_cosmetic   user_cosmetic?   @relation(fields: [user_cosmetic_user_id, user_cosmetic_cosmetic_id], references: [user_id, cosmetic_id], onDelete: SetNull)

  @@index([user_id, created_at])
  @@index([workout_session_id])
}

// ============== Missions & Partners ==============

model partner {
  id           String   @id @default(cuid())
  name         String
  logo_key     String
  bio          String   @db.Text
  social_links String[]
  created_at   DateTime @default(now()) @db.Timestamptz
  updated_at   DateTime @updatedAt @db.Timestamptz

  missions mission[]
}

model mission {
  id                 String    @id @default(cuid())
  partner_id         String?
  title              String
  description        String    @db.Text
  goal_type          String
  goal_to_reach      Int
  reward_title       String?
  reward_description String?   @db.Text
  reward_image_key   String?
  max_winners        Int?
  is_repeatable      Boolean   @default(false)
  starts_at          DateTime? @db.Timestamptz
  ends_at            DateTime? @db.Timestamptz
  created_at         DateTime  @default(now()) @db.Timestamptz
  updated_at         DateTime  @updatedAt @db.Timestamptz

  partner       partner?       @relation(fields: [partner_id], references: [id], onDelete: SetNull)
  user_missions user_mission[]

  @@index([partner_id])
  @@index([starts_at, ends_at])
}

model user_mission {
  id         String   @id @default(cuid())
  user_id    String
  mission_id String
  status     String
  progress   Int      @default(0)
  created_at DateTime @default(now()) @db.Timestamptz
  updated_at DateTime @updatedAt @db.Timestamptz

  user           user           @relation(fields: [user_id], references: [supabase_auth_id], onDelete: Cascade)
  mission        mission        @relation(fields: [mission_id], references: [id], onDelete: Cascade)
  raffle_entries raffle_entry[]

  @@unique([user_id, mission_id])
  @@index([user_id])
  @@index([mission_id])
}

model raffle_entry {
  id              String   @id @default(cuid())
  user_mission_id String
  is_winner       Boolean  @default(false)
  created_at      DateTime @default(now()) @db.Timestamptz
  updated_at      DateTime @updatedAt @db.Timestamptz

  user_mission user_mission @relation(fields: [user_mission_id], references: [id], onDelete: Cascade)

  @@index([user_mission_id])
}

// ============== Subscription Domain ==============

model subscription_plan {
  id                String       @id @default(cuid())
  name              String       @unique
  description       String       @db.Text
  features          String[]
  tier_level        Int          @default(0) // 0=Free, 1=Basic, 2=Premium, 3=Pro
  billing_cycle     BillingCycle
  price_cents       Int
  currency          String       @default("PHP")
  trial_period_days Int?
  is_active         Boolean      @default(true)
  sort_order        Int          @default(0)
  created_at        DateTime     @default(now()) @db.Timestamptz
  updated_at        DateTime     @updatedAt @db.Timestamptz

  provider_plans              provider_plan[]
  subscriptions               subscription[]
  payment_histories           payment_history[]
  subscription_plan_histories subscription_plan_history[]

  @@index([is_active, sort_order])
}

model provider_plan {
  id                       String   @id @default(cuid())
  subscription_plan_id     String
  provider                 Provider
  provider_product_id      String
  provider_subscription_id String?
  provider_base_plan_id    String?
  provider_metadata        Json?
  is_active                Boolean  @default(true)
  created_at               DateTime @default(now()) @db.Timestamptz
  updated_at               DateTime @updatedAt @db.Timestamptz

  subscription_plan subscription_plan @relation(fields: [subscription_plan_id], references: [id], onDelete: Cascade)

  @@unique([provider, provider_product_id])
  @@index([provider, provider_subscription_id])
  @@index([subscription_plan_id])
}

model subscription {
  id                       String             @id @default(cuid())
  user_id                  String
  subscription_plan_id     String
  provider                 Provider
  status                   SubscriptionStatus
  external_subscription_id String             @unique
  // Billing cycle tracking
  start_date               DateTime           @db.Timestamptz
  current_period_start     DateTime           @db.Timestamptz
  current_period_end       DateTime           @db.Timestamptz // CRITICAL: auth middleware WHERE > now()
  next_billing_date        DateTime           @db.Timestamptz
  // Cancellation
  cancel_at_period_end     Boolean            @default(false)
  canceled_at              DateTime?          @db.Timestamptz
  ended_at                 DateTime?          @db.Timestamptz
  // Trial
  trial_start_date         DateTime?          @db.Timestamptz
  trial_end_date           DateTime?          @db.Timestamptz
  // Provider-specific
  purchase_token           String?
  order_id                 String?
  auto_renew               Boolean            @default(true)
  provider_metadata        Json?
  // Discount tracking
  is_discounted            Boolean            @default(false)
  discount_description     String?
  created_at               DateTime           @default(now()) @db.Timestamptz
  updated_at               DateTime           @updatedAt @db.Timestamptz

  user                        user                        @relation(fields: [user_id], references: [supabase_auth_id], onDelete: Cascade)
  subscription_plan           subscription_plan           @relation(fields: [subscription_plan_id], references: [id], onDelete: Restrict)
  payment_histories           payment_history[]
  subscription_events         subscription_event[]
  subscription_plan_histories subscription_plan_history[]

  @@index([user_id, status, current_period_end]) // auth middleware hot path
  @@index([purchase_token])
  @@index([user_id, created_at])
}

model subscription_plan_history {
  id                   String    @id @default(cuid())
  subscription_id      String
  subscription_plan_id String
  effective_from       DateTime  @db.Timestamptz
  effective_until      DateTime? @db.Timestamptz // NULL = current plan
  change_reason        String?
  created_at           DateTime  @default(now()) @db.Timestamptz

  subscription      subscription      @relation(fields: [subscription_id], references: [id], onDelete: Cascade)
  subscription_plan subscription_plan @relation(fields: [subscription_plan_id], references: [id], onDelete: Restrict)

  @@index([subscription_id, effective_until])
  @@index([subscription_id, effective_from])
}

model payment_history {
  id                   String        @id @default(cuid())
  user_id              String
  subscription_id      String
  subscription_plan_id String
  provider             Provider
  amount_cents         Int
  currency             String
  payment_date         DateTime      @db.Timestamptz
  provider_order_id    String
  status               PaymentStatus @default(COMPLETED)
  payment_method       String?
  // Refund tracking
  refunded_at          DateTime?     @db.Timestamptz
  refund_amount_cents  Int?
  refund_reason        String?
  created_at           DateTime      @default(now()) @db.Timestamptz
  updated_at           DateTime      @updatedAt @db.Timestamptz

  user              user              @relation(fields: [user_id], references: [supabase_auth_id], onDelete: Restrict)
  subscription      subscription      @relation(fields: [subscription_id], references: [id], onDelete: Restrict)
  subscription_plan subscription_plan @relation(fields: [subscription_plan_id], references: [id], onDelete: Restrict)

  @@unique([subscription_id, provider_order_id])
  @@index([user_id, payment_date])
  @@index([status])
}

model webhook_event {
  id              String        @id @default(cuid())
  idempotency_key String        @unique
  provider        Provider
  event_type      String
  subscription_id String?
  raw_payload     Json
  status          WebhookStatus @default(PENDING)
  error_message   String?       @db.Text
  retry_count     Int           @default(0)
  processed_at    DateTime?     @db.Timestamptz // Set on completion (not on creation)
  ip_address      String?
  user_agent      String?
  created_at      DateTime      @default(now()) @db.Timestamptz
  updated_at      DateTime      @updatedAt @db.Timestamptz

  subscription_events subscription_event[]

  @@index([status, created_at])
  @@index([subscription_id])
  @@index([provider, event_type])
}

model subscription_event {
  id               String              @id @default(cuid())
  subscription_id  String
  event_type       String
  from_status      SubscriptionStatus?
  to_status        SubscriptionStatus?
  triggered_by     String?
  reason           String?             @db.Text
  webhook_event_id String?
  metadata         Json?
  created_at       DateTime            @default(now()) @db.Timestamptz

  subscription  subscription   @relation(fields: [subscription_id], references: [id], onDelete: Cascade)
  webhook_event webhook_event? @relation(fields: [webhook_event_id], references: [id], onDelete: SetNull)

  @@index([subscription_id, created_at])
  @@index([webhook_event_id])
}
