# Server Configuration
PORT=3000

# Logging Configuration
# Options: DEBUG, INFO, WARN, ERROR
LOG_LEVEL=DEBUG

# Database Configuration
DATABASE_URL="prisma+postgres://localhost:512"

# JWT Configuration (Required)
# Generate a secure random string for production: openssl rand -base64 64
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRATION=7d

# Google OAuth Configuration (Optional - for Sign in with Google)
# Get credentials from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# Supabase Configuration (Required)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Web App URL (where Supabase redirects after email actions)
WEB_APP_URL=https://your-web-app.com

# Supabase redirect URLs (constructed from WEB_APP_URL)
EMAIL_VERIFICATION_REDIRECT_URL=https://your-web-app.com/auth/confirm

# Brevo Transactional Email
BREVO_API_KEY=xkeysib-your-api-key
BREVO_SENDER_EMAIL=noreply@getgains.app
BREVO_SENDER_NAME=Get Gains

S3_ENDPOINT=https://your-s3-compatible-endpoint.com
S3_ACCESS_KEY_ID=your-s3-access-key-id
S3_SECRET_ACCESS_KEY=your-s3-secret-access-key
S3_REGION=us-east-1
S3_BUCKET_NAME=your-s3-bucket-name

# RevenueCat Configuration
REVENUECAT_API_KEY=your-revenuecat-v2-secret-api-key
REVENUECAT_AUTH_HEADER=Bearer your-revenuecat-webhook-auth-secret
REVENUECAT_PROJECT_ID=your-revenuecat-project-id